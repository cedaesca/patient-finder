# ============================================================
# Patient Finder API — Production .env template
# ============================================================

# --- Imagen ---------------------------------------------------
API_IMAGE_TAG=latest

# --- App ------------------------------------------------------
APP_ENV=production
PORT=8080

# --- CORS -----------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://pacientesvenezuela.help

# --- JWT ------------------------------------------------------
JWT_ACCESS_TOKEN_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__
JWT_REFRESH_TOKEN_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__

# --- Database -------------------------------------------------
DB_HOST=psql
DB_PORT=5432
DB_DATABASE=patient_finder
DB_USERNAME=patient_finder
DB_PASSWORD=__REPLACE_WITH_OPENSSL_RAND_HEX_24__
DB_SCHEMA=public
DATABASE_URL=postgres://patient_finder:__REPLACE_WITH_SAME_AS_DB_PASSWORD__@psql:5432/patient_finder?sslmode=disable&search_path=public

# --- Logging --------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# --- SMTP (Mailpit local o servicio real) ---------------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=NOAUTH
MAIL_FROM_NAME="Patient Finder"
MAIL_FROM=no-reply@pacientesvenezuela.help

# --- TypeSense ------------------------------------------------
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=__REPLACE_WITH_OPENSSL_RAND_HEX_24__

# --- OpenTelemetry / New Relic --------------------------------
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_RESOURCE_ATTRIBUTES=service.name=patient-finder-api,service.namespace=backend,deployment.environment=production
NEW_RELIC_API_KEY=__REPLACE__
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net:4318
