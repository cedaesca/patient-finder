# ============================================================
# Patient Finder API — Staging .env template
# ------------------------------------------------------------
# Copia este archivo a /opt/apps/patient-finder-api/.env en el
# VPS, rellena los secretos, y nunca lo commitees con valores
# reales.  Generar secretos: `openssl rand -base64 32`
# ============================================================

# --- Imagen ---------------------------------------------------
# Tag de la imagen a desplegar. CI pushea ":latest" y ":<sha>".
# Para rollback, fija un sha concreto aquí y reinicia el contenedor.
# Ojo: el próximo deploy de CI sobrescribe docker-compose.yml en el VPS,
# por eso este pin se hace en .env (nunca lo toca CI), no en el compose.
API_IMAGE_TAG=latest

# --- App ------------------------------------------------------
APP_ENV=staging
PORT=8080
WEB_CLIENT_URL=https://app.patient-finder.com
CORS_ALLOWED_ORIGINS=https://app.patient-finder.com
MAIL_DRIVER=smtp
PFINDER_DISABLE_RATE_LIMITING=false

# --- JWT ------------------------------------------------------
JWT_ACCESS_TOKEN_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__
JWT_REFRESH_TOKEN_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__
JWT_REGISTRATION_TOKEN_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__

# --- Database -------------------------------------------------
# Hostname interno del compose (servicio "psql"). El VPS no
# expone Postgres al exterior. DATABASE_URL es lo que consume
# goose en el sidecar de migraciones.
DB_HOST=psql
DB_PORT=5432
DB_DATABASE=patient_finder
DB_USERNAME=patient_finder
DB_PASSWORD=__REPLACE__
DB_SCHEMA=public
DATABASE_URL=postgres://patient_finder:__REPLACE__@psql:5432/patient_finder?sslmode=disable

# --- Logging --------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# --- Mail (Mailpit stub interno) ------------------------------
# Hasta que configuremos un proveedor SMTP real (SES/Postmark),
# Mailpit recibe todo y deja inspeccionar el inbox vía SSH
# tunnel: `ssh -L 8025:mailpit:8025 deploy@vps` y abrir
# http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=staging
SMTP_PASSWORD=staging
SMTP_AUTH=NOAUTH
MAIL_FROM_NAME=Patient Finder Staging
MAIL_FROM=no-reply@staging.patient-finder.com

# --- Centrifugo realtime --------------------------------------
# CENTRIFUGO_API_URL lo sobrescribe el compose con el hostname
# interno; deja este valor como referencia.
CENTRIFUGO_API_URL=http://centrifugo:8000/api
CENTRIFUGO_API_KEY=__REPLACE__
CENTRIFUGO_TOKEN_HMAC_SECRET=__REPLACE_WITH_OPENSSL_RAND_BASE64_32__
# Origen aceptado por Centrifugo para conexiones WS desde el
# browser. Coincidir con el dominio del frontend.
CENTRIFUGO_ALLOWED_ORIGINS=https://app.patient-finder.com

# --- OpenTelemetry / New Relic --------------------------------
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# El otel-collector interno del compose habla HTTP plano (puerto 4318), no
# HTTPS. INSECURE=true le dice al SDK que use http://. La encripción al hop
# externo (collector → New Relic) la hace el propio collector.
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_RESOURCE_ATTRIBUTES=service.name=patient-finder-api,service.namespace=backend,deployment.environment=staging
NEW_RELIC_API_KEY=__REPLACE__
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net:4318



